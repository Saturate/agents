flowchart TD
    subgraph flow["make-pr workflow"]
        direction TB
        S1["Step 0: Verified prerequisites (git repo, platform, CLI tools, auth)"]
        S2["Step 1: Parsed user arguments"]
        S1 --> S2
        S3["Step 2: Got current state (branch, remote, target branch)"]
        S2 --> S3
        S4["Step 3: Analyzed commits (found commits to PR)"]
        S3 --> S4
        S5["Step 3b: Checked for PR template and CONTRIBUTING.md"]
        S4 --> S5
        S6["Step 3c: Self-review"]
        S5 --> S6
        S6 -->|"findings"| FIX6["Fix + re-review"]
        FIX6 -->|"loop"| S6
        S7["Step 4: Generated PR title and description"]
        S6 --> S7
        S8["Step 5: Confirmed PR content with user"]
        S7 --> S8
        S9["Step 6: Created PR successfully"]
        S8 --> S9
        S10["Step 7: Displayed PR URL and details"]
        S9 --> S10

        INV_code-review("/code-review"):::invoke
        INV_make-pr("/make-pr"):::invoke
    end

    style flow fill:#1e1e2e,stroke:#89b4fa,color:#cdd6f4
    classDef invoke fill:#302040,stroke:#cba6f7,color:#cdd6f4

